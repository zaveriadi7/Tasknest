<link rel="stylesheet" href="/dashboard.css">
<div class="dashboard-container">
    <h1>Your TasksNest</h1>

   
    <form class="task-form" action="/tasks/add-task" method="POST">

        <input type="text" name="title" placeholder="Task Title" required>
        <input type="text" name="description" placeholder="Task Description">
        <input type="date" name="dueDate" required>
        <button type="submit">Add Task</button>
    </form>

    
    <div class="task-list">
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% tasks.forEach(task => { %>
                    <tr>
                        <td><%= task.title %></td>
                        <td><%= task.description %></td>
                        <td><%= task.due_date ? new Date(task.due_date).toLocaleDateString() : 'N/A' %></td>
            <td>
                        
                        <td class="task-item-actions">
                            <form action="/tasks/update-task/<%= task.id %>" method="POST">
                                <label for="file-upload"></label>
                                <input type="file" id="file-upload" name="task_file">
                            </form>
                            
                            <form action="/tasks/delete-task/<%= task.id %>" method="POST">
                                <button type="submit" class="delete-btn">Delete</button>
                            </form>
                            
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
